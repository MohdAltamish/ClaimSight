# Required for durable hosted jobs. The app uses a local in-memory store when omitted.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Required for encrypted Gemini key storage in the admin panel. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# Do not use a NEXT_PUBLIC_ variable for this value.
CLAIMSIGHT_CONFIG_ENCRYPTION_KEY=

# Required by /api/cron/cleanup in production.
CRON_SECRET=

# Required to access the admin complaint queue and encrypted Gemini key controls at /admin.
CLAIMSIGHT_ADMIN_KEY=
